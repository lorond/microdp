# Demo platform defaults. Copy to .env if you want to override values.

COMPOSE_PROJECT_NAME=microdp

POSTGRES_IMAGE=postgres:18.3
POSTGRES_DB=wallet
POSTGRES_USER=wallet
POSTGRES_PASSWORD=wallet

AIRFLOW_IMAGE=microdp-airflow:0.1.0
AIRFLOW_UID=50000
AIRFLOW_ADMIN_USER=admin
AIRFLOW_ADMIN_PASSWORD=admin
# HMAC secret для task SDK (worker → api-server). Все airflow-* контейнеры должны
# использовать один и тот же ключ, иначе worker'у вернут "Invalid auth token".
# Demo-only; для prod ротировать через: openssl rand -hex 64
AIRFLOW_JWT_SECRET=68a3808048c6f1eca56fb02b43f507dd54aa7f7aa225564b1e9a97e364f15f6ca70fbb21d2dc4e996fffc007983aa8cbd2c98051e8bd0e1aee0e4208f5b8737b

REDPANDA_IMAGE=docker.redpanda.com/redpandadata/redpanda:v26.1.5
REDPANDA_CONSOLE_IMAGE=docker.redpanda.com/redpandadata/console:v3.2.0
DEBEZIUM_CONNECT_IMAGE=quay.io/debezium/connect:3.5.1.Final

GARAGE_IMAGE=dxflrs/garage:v2.3.0
GARAGE_WEBUI_IMAGE=khairul169/garage-webui:1.1.0
# RPC и admin токены Garage (32-байт hex). Demo-only; для prod регенерировать:
#   openssl rand -hex 32
GARAGE_RPC_SECRET=c81c7d36bafd5c37762bebb1f238e59f4b48190298145498bc82439ee692c6b3
GARAGE_ADMIN_TOKEN=87440d6e3a164016971646b8825de76bce47bb28d236143978527d425289d651
# S3 access/secret для Garage — используются Spark, Nessie, StarRocks и Garage WebUI.
# Garage импортирует этот key-pair автоматически при первом старте (--default-access-key).
# Garage 2.x требует key id ≥ 8 символов и secret ≥ 16 символов, иначе server падает
# с "Invalid default access key". Для demo секрет всё равно слабый; в prod использовать:
#   openssl rand -hex 16
S3_ACCESS_KEY=microdp-admin
S3_SECRET_KEY=acd89566c5c2f7a89c901af55d96cef4
NESSIE_IMAGE=ghcr.io/projectnessie/nessie:0.107.5

STARROCKS_FE_IMAGE=starrocks/fe-ubuntu:4.0.10
STARROCKS_BE_IMAGE=starrocks/be-ubuntu:4.0.10
MYSQL_CLIENT_IMAGE=mysql:9.7.0

SUPERSET_IMAGE=microdp-superset:0.1.0
SUPERSET_ADMIN_USER=admin
SUPERSET_ADMIN_PASSWORD=admin
# REQUIRED: replace with a real random secret. Bootstrap fails fast on the placeholder.
# Generate: openssl rand -hex 32
SUPERSET_SECRET_KEY=change-me-for-local-demo-only

# DEMO_USER_ID is only consumed by scripts/smoke.sh as an override knob.
# Default in smoke.sh matches one of the emulator users so manual-demo user ...001
# does not drift between smoke runs.
DEMO_USER_ID=00000000-0000-0000-0000-000000000002
# Emulator pool. User ...001 is reserved for manual demo and intentionally excluded.
DEMO_USER_IDS=00000000-0000-0000-0000-000000000002,00000000-0000-0000-0000-000000000003
KAFKA_BOOTSTRAP_SERVERS=redpanda:9092
CLICKSTREAM_TOPIC=clickstream.events
CLICKSTREAM_DLQ_TOPIC=clickstream.events.dlq

# Transaction emulator: set EMULATOR_ENABLED=false for a clean reproducible demo.
EMULATOR_ENABLED=true
TRANSACTIONS_PER_MINUTE=6
